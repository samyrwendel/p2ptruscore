# Configuração do TrustScore Bot
# Copie este arquivo para .env e preencha com seus valores reais

# Token do bot Telegram (obtenha em @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Username do bot (sem @)
TELEGRAM_BOT_USERNAME=your_bot_username

# ID do grupo Telegram onde o bot atuará
# Para obter o ID do link: https://t.me/c/2907400287/250 -> use -1002907400287
TELEGRAM_GROUP_ID=-1002907400287

# ID do tópico específico no grupo (opcional)
# Se não definido, as mensagens serão enviadas no chat geral do grupo
TELEGRAM_THREAD_ID=250

# MongoDB Connection String - Configure com sua VPS MongoDB
# Exemplos:
# MongoDB local: mongodb://localhost:27017/trustscore
# MongoDB com autenticação: mongodb://usuario:senha@ip_da_vps:27017/trustscore
# MongoDB Atlas: mongodb+srv://usuario:senha@cluster.mongodb.net/trustscore
MONGODB_CNN=mongodb://localhost:27017/trustscore

# Porta da aplicação
PORT=3001

# Ambiente de execução
NODE_ENV=production

# API de Cotação
CURRENCY_API_KEY=your_api_key_here
CURRENCY_API_URL=https://economia.awesomeapi.com.br/json/last
DEFAULT_CURRENCY=BRL