# Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_P2P_GROUP_ID=-1001234567890
TELEGRAM_P2P_THREAD_ID=0
TELEGRAM_ADMIN_CHANNEL_ID=-1001234567890

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/trustp2p

# Environment
NODE_ENV=development

# API Configuration
# Porta da API (FIXA)
# IMPORTANTE: NUNCA altere esta porta.
# Sempre use 3031 e, em caso de conflito (EADDRINUSE),
# encerre a outra instância que estiver ocupando a porta com:
#   ss -ltnp | grep ':3031 '
#   kill <PID_encontrado>
# Nunca use comandos globais que derrubem a sessão (ex.: pkill -f "node.*main").
PORT=3031

# Security
JWT_SECRET=your_jwt_secret_here

# Logging
LOG_LEVEL=info

# Features
ENABLE_KARMA_SYSTEM=true
ENABLE_REPUTATION_SYSTEM=true
ENABLE_DISPUTE_NOTIFICATIONS=true