<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: #2c3e50;
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .header p {
            opacity: 0.9;
            font-size: 1.1em;
        }
        
        .content {
            padding: 40px;
        }
        
        .status {
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .status.configured {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        
        .status.not-configured {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        
        .form-group {
            margin-bottom: 25px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #2c3e50;
        }
        
        .form-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 8px;
            margin: 30px 0;
            border-left: 4px solid #007bff;
        }
        
        .form-section h3 {
            margin: 0 0 20px 0;
            color: #007bff;
            font-size: 1.2em;
        }
        
        .form-group input, .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e1e8ed;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s;
        }
        
        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
        }
        
        .form-group small {
            display: block;
            margin-top: 5px;
            color: #6c757d;
            font-size: 14px;
        }
        
        .btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
            margin-right: 10px;
        }
        
        .btn:hover {
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: #6c757d;
        }
        
        .alert {
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            display: none;
        }
        
        .alert.success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        
        .alert.error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        
        .help-links {
            text-align: center;
            margin-top: 30px;
            padding-top: 30px;
            border-top: 1px solid #e1e8ed;
        }
        
        .help-links a {
            color: #667eea;
            text-decoration: none;
            margin: 0 15px;
            font-weight: 500;
        }
        
        .help-links a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🤖 TrustScore Bot</h1>
            <p>Configuração Inicial do Sistema</p>
        </div>
        
        <div class="content">
            {{#if isConfigured}}
                <div class="status configured">
                    ✅ <strong>Bot Configurado!</strong><br>
                    O sistema está pronto para uso. Você pode ajustar as configurações abaixo se necessário.
                </div>
            {{else}}
                <div class="status not-configured">
                    ⚠️ <strong>Configuração Necessária</strong><br>
                    Configure o token do bot e outras informações para começar a usar o sistema.
                </div>
            {{/if}}
            
            <div id="alert" class="alert"></div>
            
            <form id="configForm">
                <div class="form-group">
                    <label for="TELEGRAM_BOT_TOKEN">🔑 Token do Bot Telegram</label>
                    <input type="text" id="TELEGRAM_BOT_TOKEN" name="TELEGRAM_BOT_TOKEN" 
                           value="{{config.TELEGRAM_BOT_TOKEN}}" 
                           placeholder="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz">
                    <small>Obtenha em @BotFather no Telegram</small>
                </div>
                
                <div class="form-group">
                    <label for="TELEGRAM_BOT_USERNAME">👤 Username do Bot</label>
                    <input type="text" id="TELEGRAM_BOT_USERNAME" name="TELEGRAM_BOT_USERNAME" 
                           value="{{config.TELEGRAM_BOT_USERNAME}}" 
                           placeholder="meu_bot">
                    <small>Username sem @ (exemplo: trustscore_bot)</small>
                </div>
                
                <div class="form-group">
                    <label for="TELEGRAM_GROUP_ID">👥 ID do Grupo Telegram</label>
                    <input type="text" id="TELEGRAM_GROUP_ID" name="TELEGRAM_GROUP_ID" 
                           value="{{config.TELEGRAM_GROUP_ID}}" 
                           placeholder="-1002907400287">
                    <small>ID do grupo onde o bot pode enviar mensagens (um por linha). Para obter o ID: adicione o bot ao grupo, use /start e verifique os logs do servidor.</small>
                </div>
                
                <div class="form-group">
                    <label for="TELEGRAM_THREAD_ID">💬 ID do Tópico (Thread)</label>
                    <input type="number" id="TELEGRAM_THREAD_ID" name="TELEGRAM_THREAD_ID" 
                           value="{{config.TELEGRAM_THREAD_ID}}" 
                           placeholder="250">
                    <small>ID do tópico específico no grupo (opcional)</small>
                </div>
                
                <div class="form-group">
                    <label for="MONGODB_CNN">🗄️ MongoDB Connection</label>
                    <input type="text" id="MONGODB_CNN" name="MONGODB_CNN" 
                           value="{{config.MONGODB_CNN}}">
                    <small>String de conexão do MongoDB (já configurada para Docker)</small>
                </div>
                
                <div class="form-group">
                    <label for="PORT">🌐 Porta da Aplicação</label>
                    <input type="number" id="PORT" name="PORT" 
                           value="{{config.PORT}}" min="1000" max="65535">
                    <small>Porta onde a aplicação será executada</small>
                </div>
                
                <!-- Seção API de Cotação -->
                <div class="form-section">
                    <h3>💱 API de Cotação</h3>
                    
                    <div class="form-group">
                        <label for="CURRENCY_API_KEY">🔑 Chave da API de Cotação</label>
                        <input type="password" id="CURRENCY_API_KEY" name="CURRENCY_API_KEY" 
                               value="{{config.CURRENCY_API_KEY}}" 
                               placeholder="sua_api_key_aqui">
                        <small>Chave da API para cotações automáticas (ex: CoinGecko, CoinMarketCap)</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="CURRENCY_API_URL">🌐 URL da API de Cotação</label>
                        <input type="url" id="CURRENCY_API_URL" name="CURRENCY_API_URL" 
                               value="{{config.CURRENCY_API_URL}}" 
                               placeholder="https://api.coingecko.com/api/v3">
                        <small>URL base da API de cotação</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="DEFAULT_CURRENCY">💰 Moeda Padrão</label>
                        <select id="DEFAULT_CURRENCY" name="DEFAULT_CURRENCY">
                            <option value="BRL" {{#if (eq config.DEFAULT_CURRENCY 'BRL')}}selected{{/if}}>BRL - Real Brasileiro</option>
                            <option value="USD" {{#if (eq config.DEFAULT_CURRENCY 'USD')}}selected{{/if}}>USD - Dólar Americano</option>
                            <option value="EUR" {{#if (eq config.DEFAULT_CURRENCY 'EUR')}}selected{{/if}}>EUR - Euro</option>
                        </select>
                        <small>Moeda padrão para cotações</small>
                    </div>
                    
                    <div class="form-group">
                        <button type="button" class="btn btn-secondary" onclick="testCurrencyAPI()" style="width: 100%;">
                            💱 Testar API de Cotação (USD/BRL)
                        </button>
                        <small>Testa a conexão com a API e busca a cotação atual do dólar</small>
                    </div>
                </div>
                
                <button type="submit" class="btn">💾 Salvar Configuração</button>
                <button type="button" class="btn btn-secondary" onclick="testConnection()">🔍 Testar Conexão</button>
            </form>
            
            <div class="help-links">
                <a href="/setup/help">📚 Ajuda</a>
                <a href="/config/status">📊 Status do Sistema</a>
                <a href="http://localhost:8081" target="_blank">🗄️ MongoDB Express</a>
            </div>
        </div>
    </div>
    
    <script>
        document.getElementById('configForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const config = Object.fromEntries(formData.entries());
            
            try {
                const response = await fetch('/setup/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(config)
                });
                
                const result = await response.json();
                
                const alert = document.getElementById('alert');
                alert.style.display = 'block';
                
                if (result.success) {
                    alert.className = 'alert success';
                    alert.innerHTML = '✅ ' + result.message;
                    
                    if (result.restart_required) {
                        setTimeout(() => {
                            alert.innerHTML += '<br><br>🔄 <strong>Reinicie o container Docker para aplicar as mudanças.</strong>';
                        }, 2000);
                    }
                } else {
                    alert.className = 'alert error';
                    alert.innerHTML = '❌ ' + result.message;
                }
            } catch (error) {
                const alert = document.getElementById('alert');
                alert.style.display = 'block';
                alert.className = 'alert error';
                alert.innerHTML = '❌ Erro ao salvar: ' + error.message;
            }
        });
        
        async function testConnection() {
            const alert = document.getElementById('alert');
            alert.style.display = 'block';
            alert.className = 'alert';
            alert.innerHTML = '📤 Enviando mensagem de teste...';
            
            try {
                const response = await fetch('/config/test-message', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        message: '🤖 Teste de conexão do TrustScore Bot - ' + new Date().toLocaleString('pt-BR')
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    alert.className = 'alert success';
                    let message = '✅ Mensagem de teste enviada com sucesso!<br>';
                    
                    if (result.results && result.results.botInfo) {
                        message += '<small>Bot: ' + result.results.botInfo.first_name + ' (@' + result.results.botInfo.username + ')</small><br>';
                    }
                    
                    if (result.results && result.results.sent) {
                        const groupMessages = result.results.sent.filter(s => s.type === 'group');
                        const simulations = result.results.sent.filter(s => s.type === 'simulation');
                        
                        if (groupMessages.length > 0) {
                            message += '<small>Enviado para ' + groupMessages.length + ' grupo(s)</small>';
                        } else if (simulations.length > 0) {
                            message += '<small>⚠️ ' + simulations[0].message + '</small>';
                        }
                    }
                    
                    alert.innerHTML = message;
                } else {
                    alert.className = 'alert error';
                    alert.innerHTML = '❌ Erro ao enviar mensagem: ' + (result.message || 'Erro desconhecido');
                }
            } catch (error) {
                alert.className = 'alert error';
                alert.innerHTML = '❌ Erro ao testar conexão: ' + error.message;
            }
        }
        
        async function testCurrencyAPI() {
            const alert = document.getElementById('alert');
            alert.style.display = 'block';
            alert.className = 'alert';
            alert.innerHTML = '💱 Testando API de cotação...';
            
            try {
                const response = await fetch('/config/test-currency', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        from: 'USD',
                        to: 'BRL'
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                     alert.className = 'alert success';
                     alert.innerHTML = '✅ API de cotação funcionando!<br>' +
                                     '<strong>USD/BRL: R$ ' + result.rate.toFixed(4) + '</strong><br>' +
                                     '<small>Fonte: ' + result.source + ' | API: ' + result.apiUsed + ' | Atualizado: ' + new Date(result.timestamp).toLocaleString('pt-BR') + '</small>';
                 } else {
                     alert.className = 'alert error';
                     alert.innerHTML = '❌ Erro na API de cotação: ' + (result.message || 'Erro desconhecido');
                 }
            } catch (error) {
                alert.className = 'alert error';
                alert.innerHTML = '❌ Erro ao testar API de cotação: ' + error.message;
            }
        }
    </script>
</body>
</html>