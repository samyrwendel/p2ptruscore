<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        
        .header {
            background: #2c3e50;
            color: white;
            padding: 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }
        
        .header p {
            opacity: 0.9;
            font-size: 1.1em;
        }
        
        .content {
            padding: 40px;
        }
        
        {{#if hasError}}
        .error-status {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            text-align: center;
        }
        {{else}}
        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .status-card {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            border-left: 4px solid #007bff;
            transition: transform 0.2s;
        }
        
        .status-card:hover {
            transform: translateY(-2px);
        }
        
        .status-card.healthy {
            border-left-color: #28a745;
        }
        
        .status-card.warning {
            border-left-color: #ffc107;
        }
        
        .status-card.error {
            border-left-color: #dc3545;
        }
        
        .status-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .status-icon {
            font-size: 1.5em;
            margin-right: 10px;
        }
        
        .status-title {
            font-weight: 600;
            color: #2c3e50;
            font-size: 1.1em;
        }
        
        .status-value {
            font-size: 1.3em;
            font-weight: 700;
            margin-bottom: 5px;
        }
        
        .status-value.healthy {
            color: #28a745;
        }
        
        .status-value.warning {
            color: #ffc107;
        }
        
        .status-value.error {
            color: #dc3545;
        }
        
        .status-details {
            color: #6c757d;
            font-size: 0.9em;
            line-height: 1.4;
        }
        
        .info-section {
            background: #f8f9fa;
            padding: 25px;
            border-radius: 8px;
            margin: 30px 0;
            border-left: 4px solid #007bff;
        }
        
        .info-section h3 {
            margin: 0 0 20px 0;
            color: #007bff;
            font-size: 1.2em;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }
        
        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #e1e8ed;
        }
        
        .info-item:last-child {
            border-bottom: none;
        }
        
        .info-label {
            font-weight: 600;
            color: #2c3e50;
        }
        
        .info-value {
            color: #6c757d;
        }
        
        .refresh-section {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e1e8ed;
        }
        
        .btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s;
            text-decoration: none;
            display: inline-block;
        }
        
        .btn:hover {
            transform: translateY(-2px);
        }
        
        .last-update {
            color: #6c757d;
            font-size: 0.9em;
            margin-top: 15px;
        }
        {{/if}}
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🤖 TrustScore Bot</h1>
            <p>Status do Sistema</p>
        </div>
        
        <div class="content">
            {{#if hasError}}
            <div class="error-status">
                <h2>❌ Erro no Sistema</h2>
                <p><strong>{{message}}</strong></p>
                {{#if details}}
                <p><small>{{details}}</small></p>
                {{/if}}
            </div>
            {{else}}
            <div class="status-grid">
                <div class="status-card {{#if (eq status.overall 'healthy')}}healthy{{else}}{{#if (eq status.overall 'degraded')}}warning{{else}}error{{/if}}{{/if}}">
                    <div class="status-header">
                        <span class="status-icon">{{#if (eq status.overall 'healthy')}}✅{{else}}{{#if (eq status.overall 'degraded')}}⚠️{{else}}❌{{/if}}{{/if}}</span>
                        <span class="status-title">Status Geral</span>
                    </div>
                    <div class="status-value {{#if (eq status.overall 'healthy')}}healthy{{else}}{{#if (eq status.overall 'degraded')}}warning{{else}}error{{/if}}{{/if}}">
                        {{#if (eq status.overall 'healthy')}}Saudável{{else}}{{#if (eq status.overall 'degraded')}}Degradado{{else}}Erro{{/if}}{{/if}}
                    </div>
                    <div class="status-details">Sistema {{#if (eq status.overall 'healthy')}}funcionando normalmente{{else}}com problemas{{/if}}</div>
                </div>
                
                <div class="status-card {{#if (eq status.telegram.status 'connected')}}healthy{{else}}error{{/if}}">
                    <div class="status-header">
                        <span class="status-icon">{{#if (eq status.telegram.status 'connected')}}✅{{else}}❌{{/if}}</span>
                        <span class="status-title">Telegram Bot</span>
                    </div>
                    <div class="status-value {{#if (eq status.telegram.status 'connected')}}healthy{{else}}error{{/if}}">
                        {{#if (eq status.telegram.status 'connected')}}Conectado{{else}}Desconectado{{/if}}
                    </div>
                    <div class="status-details">
                        {{#if status.telegram.botInfo}}
                        @{{status.telegram.botInfo.username}} ({{status.telegram.botInfo.first_name}})
                        {{else}}
                        {{#if status.telegram.error}}{{status.telegram.error}}{{else}}Status desconhecido{{/if}}
                        {{/if}}
                    </div>
                </div>
                
                <div class="status-card {{#if (eq status.mongodb.status 'connected')}}healthy{{else}}{{#if (eq status.mongodb.status 'connecting')}}warning{{else}}error{{/if}}{{/if}}">
                    <div class="status-header">
                        <span class="status-icon">{{#if (eq status.mongodb.status 'connected')}}✅{{else}}{{#if (eq status.mongodb.status 'connecting')}}🔄{{else}}❌{{/if}}{{/if}}</span>
                        <span class="status-title">MongoDB</span>
                    </div>
                    <div class="status-value {{#if (eq status.mongodb.status 'connected')}}healthy{{else}}{{#if (eq status.mongodb.status 'connecting')}}warning{{else}}error{{/if}}{{/if}}">
                        {{#if (eq status.mongodb.status 'connected')}}Conectado{{else}}{{#if (eq status.mongodb.status 'connecting')}}Conectando{{else}}Desconectado{{/if}}{{/if}}
                    </div>
                    <div class="status-details">
                        {{#if status.mongodb.error}}
                        {{status.mongodb.error}}
                        {{else}}
                        Ready State: {{status.mongodb.readyState}}
                        {{/if}}
                    </div>
                </div>
                
                <div class="status-card healthy">
                    <div class="status-header">
                        <span class="status-icon">💾</span>
                        <span class="status-title">Memória</span>
                    </div>
                    <div class="status-value healthy">{{memory.used}} MB</div>
                    <div class="status-details">Total: {{memory.total}} MB | RSS: {{memory.rss}} MB</div>
                </div>
            </div>
            
            <div class="info-section">
                <h3>📊 Informações do Sistema</h3>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Uptime:</span>
                        <span class="info-value">{{formatUptime uptime}}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Tempo de Resposta:</span>
                        <span class="info-value">{{responseTime}}ms</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Node.js:</span>
                        <span class="info-value">{{environment.nodeVersion}}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Plataforma:</span>
                        <span class="info-value">{{environment.platform}}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">PID:</span>
                        <span class="info-value">{{environment.pid}}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Timestamp:</span>
                        <span class="info-value">{{formatTimestamp timestamp}}</span>
                    </div>
                </div>
            </div>
            {{/if}}
            
            <div class="refresh-section">
                <a href="/setup" class="btn">⚙️ Configurações</a>
                <button onclick="window.location.reload()" class="btn">🔄 Atualizar</button>
                <div class="last-update">
                    Página atualizada automaticamente a cada 30 segundos
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // Auto-refresh a cada 30 segundos
        setTimeout(() => {
            window.location.reload();
        }, 30000);
    </script>
</body>
</html>